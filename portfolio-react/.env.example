# Google Gemini AI API Key for Health Chatbot
VITE_GEMINI_API_KEY=your_api_key_here
VITE_API_VERSION=v1beta
VITE_MODEL_NAME=gemini-1.5-flash-latest

# RapidAPI - Amazon Reviews API Key
VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# OpenStreetMap Nominatim API Configuration for ChickenLicken Map
# Note: Nominatim doesn't require an API key for basic usage
VITE_GEOCODE_API_URL=https://nominatim.openstreetmap.org/search
